# =============================================================================
# Zarqa Agent Framework — OpenClaw Configuration
# Copy to .env, fill in your values, then run ./docker-setup.sh
# =============================================================================

# --- LLM Provider (set at least one) ---
# anthropic/claude-sonnet-4-6, openai/gpt-4o, google/gemini-2.5-flash, ollama/llama3.1:8b
OPENCLAW_MODEL=anthropic/claude-sonnet-4-6

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Ollama (local, no key needed) — also set OPENCLAW_MODEL=ollama/<model-name>
OLLAMA_HOST=http://host.docker.internal:11434

# --- Gateway ---
OPENCLAW_GATEWAY_TOKEN=           # auto-generated if empty
OPENCLAW_GATEWAY_PORT=18789

# --- Channels (optional — leave blank to skip) ---
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
# WhatsApp: pair after startup with: docker compose run --rm openclaw-cli channels login
WHATSAPP_ALLOW_FROM=              # comma-separated E.164 numbers e.g. +15555550123

# --- Channel policies ---
TELEGRAM_DM_POLICY=open           # open | allowlist | pairing | disabled
DISCORD_DM_POLICY=open
WHATSAPP_DM_POLICY=open

# --- Zarqa MCP Server ---
SUI_NETWORK=mainnet               # mainnet | testnet
ETHERSCAN_API_KEY=
ALCHEMY_API_KEY=
